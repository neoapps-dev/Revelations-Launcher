{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Revelations Launcher",
  "version": "1.1.1",
  "identifier": "com.revelations.lce",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Revelations Launcher",
        "width": 1280,
        "height": 720,
        "minWidth": 1280,
        "minHeight": 720,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' https://api.github.com https://api.mojang.com https://api.minecraftapi.net https://*.githubusercontent.com https://*.codeberg.org"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/DLC"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "signingIdentity": null,
      "providerShortName": "Revelations"
    }
  }
}
